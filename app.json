{
  "expo": {
    "name": "PlayBhoomi",
    "slug": "PlayBhoomi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/AppIconnew.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.nikhil.parit.Krida"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/AppIconnew.png",
        "backgroundColor": "#00C247"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.nikhil.parit.Krida",
      "versionCode": 1,
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "INTERNET",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-asset",
      "expo-font",
      "expo-maps",
      "@react-native-google-signin/google-signin"
    ],
    "extra": {
      "eas": {
        "projectId": "73be58cf-b854-42d3-b84e-038eb02f0372"
      }
    },
    "owner": "drinkpertinent57"
  }
}
